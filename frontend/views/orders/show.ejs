<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/catalog.css">
</head>
<body>
  <main class="page">
    <header class="catalog-header">
      <div>
        <a href="/orders" class="back-link">Back to order history</a>
        <p class="eyebrow">Order details</p>
        <h1>Order #<%= order.id %></h1>
        <p class="meta-copy">Track each item, review its status, and jump back to the product page when needed.</p>
      </div>
    </header>

    <section class="cart-panel">
      <p>Payment: <strong><%= order.payment_method %></strong></p>

      <div class="cart-table-wrap">
        <table class="cart-table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Price</th>
              <th>Quantity</th>
              <th>Subtotal</th>
              <th>Status</th>
              <th>Review</th>
            </tr>
          </thead>
          <tbody>
            <% order.items.forEach((item) => { %>
              <tr>
                <td><%= item.product_name %></td>
                <td>PHP <%= item.price.toFixed(2) %></td>
                <td><%= item.quantity %></td>
                <td>PHP <%= item.subtotal.toFixed(2) %></td>
                <td><%= item.status %></td>
                <td>
                  <% if (item.review_id) { %>
                    <a href="/reviews/<%= item.review_id %>/edit">Edit review</a>
                  <% } else if (item.status === 'Delivered') { %>
                    <a href="/shop/<%= item.product_id %>">Write review</a>
                  <% } else { %>
                    <span class="muted">Available after delivery</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="cart-summary">
        <p></p>
        <p>Total: PHP <strong><%= order.total.toFixed(2) %></strong></p>
      </div>
    </section>
  </main>
</body>
</html>
