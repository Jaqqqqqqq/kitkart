<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/catalog.css">
</head>
<body>
  <main class="page">
    <header class="catalog-header">
      <div>
        <a href="/shop" class="back-link">Back to shop</a>
        <h1><%= product.product_name %></h1>
        <p><%= product.category_name %></p>
      </div>

      <div class="catalog-actions">
        <a class="secondary-button" href="/cart">Cart</a>
        <a class="secondary-button" href="/orders">Orders</a>
        <form action="/auth/logout" method="POST">
          <button type="submit" class="danger-button">Logout</button>
        </form>
      </div>
    </header>

    <section class="product-detail">
      <div class="detail-image">
        <% if (product.image_url) { %>
          <img src="<%= product.image_url %>" alt="<%= product.product_name %>">
        <% } %>
        <span class="image-placeholder <%= product.image_url ? 'is-hidden' : '' %>">No image</span>
      </div>

      <div class="detail-info">
        <p class="price">PHP <%= Number(product.price).toFixed(2) %></p>
        <p class="stock">Stock: <%= product.stock_quantity || 0 %></p>
        <p><%= product.description || 'No description available.' %></p>

        <form class="add-to-cart-form detail-cart-form" action="/cart/items" method="POST">
          <input type="hidden" name="product_id" value="<%= product.id %>">
          <label for="quantity">Quantity</label>
          <input
            id="quantity"
            name="quantity"
            type="number"
            min="1"
            max="<%= product.stock_quantity || 0 %>"
            value="1"
            <%= Number(product.stock_quantity) < 1 ? 'disabled' : '' %>
          >
          <button type="submit" <%= Number(product.stock_quantity) < 1 ? 'disabled' : '' %>>
            Add to Cart
          </button>
          <span class="cart-message" aria-live="polite"></span>
        </form>

        <% if (product.image_urls.length > 1) { %>
          <div class="image-list">
            <% product.image_urls.forEach((imageUrl) => { %>
              <img src="<%= imageUrl %>" alt="<%= product.product_name %> image">
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>

    <section class="reviews-panel">
      <div class="reviews-header">
        <div>
          <h2>Customer Reviews</h2>
          <p>
            Average rating:
            <strong>
              <%= ratingSummary.review_count > 0 ? ratingSummary.average_rating.toFixed(1) : 'No ratings yet' %>
            </strong>
            <% if (ratingSummary.review_count > 0) { %>
              / 5 from <%= ratingSummary.review_count %> review<%= ratingSummary.review_count === 1 ? '' : 's' %>
            <% } %>
          </p>
        </div>
      </div>

      <% if (reviewEligibility.canReview) { %>
        <form action="/products/<%= product.id %>/reviews" method="POST" class="review-form">
          <h3>Write a Review</h3>

          <label for="rating">Rating</label>
          <select id="rating" name="rating" required>
            <option value="5">5 stars</option>
            <option value="4">4 stars</option>
            <option value="3">3 stars</option>
            <option value="2">2 stars</option>
            <option value="1">1 star</option>
          </select>

          <label for="review_text">Review</label>
          <textarea id="review_text" name="review_text" rows="4" required></textarea>

          <button type="submit">Submit Review</button>
        </form>
      <% } else if (reviewEligibility.existingReview) { %>
        <p class="review-note">You already reviewed this product.</p>
      <% } else { %>
        <p class="review-note">Only customers who purchased this product can leave a review.</p>
      <% } %>

      <div class="review-list">
        <% if (reviews.length === 0) { %>
          <p class="empty-message is-visible">No reviews yet.</p>
        <% } %>

        <% reviews.forEach((review) => { %>
          <article class="review-card">
            <div class="review-card-header">
              <div>
                <h3><%= review.first_name %> <%= review.last_name %></h3>
                <p>
                  <strong><%= review.rating %>/5</strong>
                  <span><%= new Date(review.created_at).toLocaleDateString() %></span>
                </p>
              </div>

              <% if (currentUser && currentUser.id === review.user_id) { %>
                <div class="review-actions">
                  <a href="/reviews/<%= review.id %>/edit">Edit</a>
                  <form action="/reviews/<%= review.id %>/delete" method="POST">
                    <button type="submit">Delete</button>
                  </form>
                </div>
              <% } %>
            </div>

            <p><%= review.review_text %></p>
          </article>
        <% }) %>
      </div>
    </section>
  </main>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="/js/catalog.js"></script>
</body>
</html>
