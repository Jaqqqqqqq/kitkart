<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
</head>
<body>
  <main>
    <h1>Register</h1>

    <% if (error) { %>
      <p><%= error %></p>
    <% } %>

    <form action="/auth/register" method="POST">
      <div>
        <label for="first_name">First Name</label>
        <input id="first_name" name="first_name" type="text" value="<%= oldInput.first_name || '' %>" required>
      </div>

      <div>
        <label for="last_name">Last Name</label>
        <input id="last_name" name="last_name" type="text" value="<%= oldInput.last_name || '' %>" required>
      </div>

      <div>
        <label for="email">Email</label>
        <input id="email" name="email" type="email" value="<%= oldInput.email || '' %>" required>
      </div>

      <div>
        <label for="password">Password</label>
        <input id="password" name="password" type="password" required>
      </div>

      <div>
        <label for="confirm_password">Confirm Password</label>
        <input id="confirm_password" name="confirm_password" type="password" required>
      </div>

      <div>
        <label for="phone">Phone</label>
        <input id="phone" name="phone" type="text" value="<%= oldInput.phone || '' %>">
      </div>

      <div>
        <label for="address">Address</label>
        <textarea id="address" name="address"><%= oldInput.address || '' %></textarea>
      </div>

      <button type="submit">Register</button>
    </form>

    <p>Already have an account? <a href="/auth/login">Login</a></p>
  </main>
</body>
</html>
