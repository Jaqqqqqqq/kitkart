<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<% const isAdmin = currentUser.role === 'admin'; %>

<nav class="navbar navbar-dark bg-dark">
<div class="container-fluid">
<span class="navbar-brand">KitKart Dashboard</span>

<form action="/auth/logout" method="POST">
<button class="btn btn-danger">
Logout
</button>
</form>
</div>
</nav>

<div class="container py-4">

<h2>
Welcome,
<%= currentUser.first_name %>
</h2>

<p class="text-muted">
<%= currentUser.email %>
</p>

<% if (isAdmin) { %>

<h3 class="mb-4">Admin Dashboard</h3>

<div class="row g-4">

<div class="col-md-3">
<div class="card shadow">
<div class="card-body text-center">
<h5>Products</h5>
<a href="/admin/products" class="btn btn-primary">
Manage
</a>
</div>
</div>
</div>

<div class="col-md-3">
<div class="card shadow">
<div class="card-body text-center">
<h5>Categories</h5>
<a href="/admin/categories" class="btn btn-success">
Manage
</a>
</div>
</div>
</div>

<div class="col-md-3">
<div class="card shadow">
<div class="card-body text-center">
<h5>Orders</h5>
<a href="/admin/orders" class="btn btn-warning">
Manage
</a>
</div>
</div>
</div>

<div class="col-md-3">
<div class="card shadow">
<div class="card-body text-center">
<h5>Users</h5>
<a href="/admin/users" class="btn btn-info">
Manage
</a>
</div>
</div>
</div>

</div>

<% } else { %>

<h3 class="mb-4">Customer Dashboard</h3>

<div class="row g-4">

<div class="col-md-4">
<div class="card shadow">
<div class="card-body text-center">
<h5>Products</h5>
<p>Browse school supplies</p>
<a href="/products" class="btn btn-primary">
Browse
</a>
</div>
</div>
</div>

<div class="col-md-4">
<div class="card shadow">
<div class="card-body text-center">
<h5>Cart</h5>
<p>View shopping cart</p>
<a href="/cart" class="btn btn-success">
Open Cart
</a>
</div>
</div>
</div>

<div class="col-md-4">
<div class="card shadow">
<div class="card-body text-center">
<h5>Orders</h5>
<p>View purchase history</p>
<a href="/orders" class="btn btn-warning">
View Orders
</a>
</div>
</div>
</div>

</div>

<% } %>

</div>

</body>
</html>