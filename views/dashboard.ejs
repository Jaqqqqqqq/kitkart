<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
</head>
<body>
  <main>
    <% const isAdmin = currentUser.role === 'admin'; %>
    <h1><%= isAdmin ? 'Admin Dashboard' : 'Customer Dashboard' %></h1>
    <p>Welcome, <%= currentUser.first_name %>.</p>
    <p>You are logged in as <%= currentUser.email %> (<%= currentUser.role %>).</p>

    <% if (isAdmin) { %>
      <section>
        <h2>Administration</h2>
        <p><a href="/admin/orders">All orders</a></p>
        <p><a href="/admin/products">Products</a></p>
        <p><a href="/admin/categories">Categories</a></p>
        <p><a href="/admin/users">User accounts</a></p>
      </section>
    <% } else { %>
      <section>
        <h2>Shopping</h2>
        <p><a href="/products">Browse school supplies</a></p>
        <p><a href="/cart">View cart</a></p>
        <p><a href="/orders">Order history</a></p>
      </section>
    <% } %>

    <form action="/auth/logout" method="POST">
      <button type="submit">Logout</button>
    </form>
  </main>
</body>
</html>
