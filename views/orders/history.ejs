<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/catalog.css">
</head>
<body>
  <main class="page">
    <header class="catalog-header">
      <div>
        <a href="/dashboard" class="back-link">Dashboard</a>
        <h1>Order History</h1>
        <p>View your previous school supplies orders.</p>
      </div>
    </header>

    <section class="cart-panel">
      <% if (orders.length === 0) { %>
        <p class="empty-message is-visible">No orders yet.</p>
      <% } else { %>
        <div class="cart-table-wrap">
          <table class="cart-table">
            <thead>
              <tr>
                <th>Order</th>
                <th>Status</th>
                <th>Payment</th>
                <th>Items</th>
                <th>Total</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% orders.forEach((order) => { %>
                <tr>
                  <td>#<%= order.id %></td>
                  <td><%= order.order_status %></td>
                  <td><%= order.payment_method %></td>
                  <td><%= order.item_count %></td>
                  <td>PHP <%= order.total.toFixed(2) %></td>
                  <td><a href="/orders/<%= order.id %>">View</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>
